# Kopieer dit bestand naar .env en vul je API key in
# Voeg .env toe aan .gitignore — deel nooit je API key!

ANTHROPIC_API_KEY=sk-ant-VERVANG-DIT-DOOR-JOUW-ECHTE-KEY

# Poort voor de server (standaard 3000)
PORT=3000

# Toegestane origin voor CORS (vervang door je domein in productie)
# Gebruik * alleen lokaal tijdens development
ALLOWED_ORIGIN=*
